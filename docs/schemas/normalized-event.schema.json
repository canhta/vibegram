{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NormalizedEvent",
  "type": "object",
  "required": [
    "event_id",
    "session_id",
    "run_id",
    "provider",
    "event_type",
    "source_class",
    "delivery_key",
    "severity",
    "timestamp",
    "summary"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "provider": {
      "type": "string",
      "enum": ["claude", "codex"]
    },
    "event_type": {
      "type": "string",
      "enum": [
        "session_started",
        "phase_changed",
        "tool_activity",
        "files_changed",
        "tests_changed",
        "question",
        "blocked",
        "approval_needed",
        "agent_reply_sent",
        "done",
        "failed"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": ["trusted_policy", "trusted_system", "untrusted_evidence"]
    },
    "delivery_key": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": ["info", "warning", "error", "critical"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string"
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source"],
        "properties": {
          "source": {
            "type": "string",
            "enum": ["hook", "transcript", "pty"]
          },
          "provider_type": {
            "type": "string"
          },
          "provider_id": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
